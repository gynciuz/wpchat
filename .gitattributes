# Files excluded from `git archive` and similar release-package commands.
# The ZIP we ship via gh release uses a hand-curated copy in scripts, not
# git archive — these are belt-and-suspenders for anyone using
# `composer create-project` against the repo.
/.github             export-ignore
/.gitattributes      export-ignore
/.gitignore          export-ignore
/.phpunit.cache      export-ignore
/bin                 export-ignore
/composer.json       export-ignore
/composer.lock       export-ignore
/phpunit.xml.dist    export-ignore
/tests               export-ignore
/app/src             export-ignore
/app/node_modules    export-ignore
/app/package.json    export-ignore
/app/package-lock.json export-ignore
/app/pnpm-lock.yaml  export-ignore
/app/vite.config.ts  export-ignore
/app/tsconfig.json   export-ignore
/app/tsconfig.app.json export-ignore
/app/tsconfig.node.json export-ignore
/app/eslint.config.js export-ignore
/app/index.html      export-ignore
