# Files excluded from `git archive` / the release ZIP (bin/release.sh).
# Runtime needs only: wpchat.php, includes/, vendor-puc/, build/, and the
# readme/license docs. Everything below is source, tooling, tests, internal
# docs, or the marketing site — none of it is loaded at runtime.
/.github             export-ignore
/.gitattributes      export-ignore
/.gitignore          export-ignore
/.phpunit.cache      export-ignore
/bin                 export-ignore
/composer.json       export-ignore
/composer.lock       export-ignore
/phpunit.xml.dist    export-ignore
/tests               export-ignore
/docs                export-ignore
/site                export-ignore
/.wp-env.json        export-ignore
# The whole React source/tooling tree — built assets ship from /build, so
# nothing under /app is needed in the plugin package.
/app                 export-ignore
# Internal dev docs + the Cloudflare Worker + editor/OS cruft — not runtime.
/CLAUDE.md           export-ignore
/TASKS.md            export-ignore
/README.md           export-ignore
/cloud               export-ignore
/.claude             export-ignore
/.DS_Store           export-ignore
